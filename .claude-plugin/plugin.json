{
  "name": "macos",
  "description": "macOS system services for Claude Code — iMessage, Calendar, and more",
  "version": "3.0.0",
  "author": {
    "name": "Felipe Oduardo Sierra"
  },
  "repository": "https://github.com/felipe/macos-mcp",
  "keywords": [
    "macos",
    "imessage",
    "calendar",
    "eventkit",
    "messages",
    "messaging",
    "channel",
    "automation",
    "daemon",
    "agent",
    "mcp"
  ],
  "license": "MIT",
  "mcpServers": {
    "macos-mcp": {
      "command": "${CLAUDE_PLUGIN_ROOT}/macos-mcp",
      "args": ["stdio"],
      "env": {
        "MACOS_MCP_OWNER_PHONE": "${MACOS_MCP_OWNER_PHONE}",
        "MACOS_MCP_OWNER_NAME": "${MACOS_MCP_OWNER_NAME}"
      }
    }
  }
}
