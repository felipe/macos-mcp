# iMessage-Claude-Bridge Configuration
# Copy this file to ~/.claude-imessage.env and edit with your details
#
# Usage:
#   cp examples/.env.example ~/.claude-imessage.env
#   nano ~/.claude-imessage.env
#   source ~/.claude-imessage.env

# Required: Phone number of the contact to monitor (digits only)
export IMESSAGE_CONTACT_PHONE="4155551234"

# Required: Display name of the contact
export IMESSAGE_CONTACT_NAME="John Doe"

# Optional: Email address if they use iMessage email
# export IMESSAGE_CONTACT_EMAIL="john@example.com"

# Optional: How often to check for new messages in seconds (default: 1)
# export IMESSAGE_CHECK_INTERVAL="1"

# Optional: Directory for logs and state files (default: ~/tmp/imessage/)
# export IMESSAGE_TMP_DIR="$HOME/tmp/imessage"
